generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  SELL
  BUY
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REJECTED
}

model User {
  id            Int            @id @default(autoincrement())
  otp           String?
  otpExpiry     DateTime?
  mobile        String         @unique
  inviteCode    String?        @unique
  referredById  Int?
  referredAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  referredBy    User?          @relation("UserReferrals", fields: [referredById], references: [id])
  referrals     User[]         @relation("UserReferrals")
  bankCards     BankCard[]
  cryptoWallets CryptoWallet[]
  wallet        Wallet?
  transactions  Transaction[]
  walletLedger  WalletLedger[]
  referralRewardsEarned ReferralReward[] @relation("ReferralRewardReferrer")
  referralRewardsFromReferrals ReferralReward[] @relation("ReferralRewardReferredUser")

  @@index([referredById, createdAt])
}

model BankCard {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  bankName   String
  accountNo  String
  ifsc       String
  payeeName  String
  isSelected Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, accountNo])
  @@index([userId, isSelected])
}

model CryptoWallet {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  address    String
  network    String   // TRC20, ERC20, etc.
  label      String?  // optional label
  isSelected Boolean  @default(false)
  currency   String   @default("USDT")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, address])
  @@index([userId, isSelected])
}

model Wallet {
  id             Int      @id @default(autoincrement())
  user           User     @relation(fields: [userId], references: [id])
  userId         Int      @unique

  usdtAvailable  Decimal  @db.Decimal(18, 6) @default(0)
  usdtLocked     Decimal  @db.Decimal(18, 6) @default(0)
  usdtDeposited  Decimal  @db.Decimal(18, 6) @default(0)
  usdtWithdrawn  Decimal  @db.Decimal(18, 6) @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Transaction {
  id          Int               @id @default(autoincrement())
  user        User              @relation(fields: [userId], references: [id])
  userId      Int
  reviewedBy  Admin?            @relation("ReviewedTransactions", fields: [adminId], references: [id])
  adminId     Int?

  referenceId String            @unique
  txnId       String?           @unique
  type        TransactionType
  amount      Decimal           @db.Decimal(18, 6)
  currency    String            @default("USDT")
  network     String?
  address     String?
  status      TransactionStatus @default(PENDING)
  description String?
  reviewNote  String?
  reviewedAt  DateTime?

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  referralRewards ReferralReward[]

  @@index([userId, createdAt])
  @@index([status, type, createdAt])
}

model Admin {
  id                  Int               @id @default(autoincrement())
  email               String            @unique
  password            String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  reviewedTransactions Transaction[]    @relation("ReviewedTransactions")
  actionLogs          AdminActionLog[]
}

model Settings {
  id          Int      @id @default(autoincrement())
  rate        Float    @default(102)
  withdrawMin Float    @default(50)
  depositMin  Float    @default(100)
  inviteReward Float   @default(1)
  trc20Address String  @default("TU7f7jwJr56owuutyzbJEwVqF3ii4KCiPV")
  erc20Address String  @default("0x78845f99b319b48393fbcde7d32fcb7ccd6661bf")
  trc20QrUrl   String  @default("images/trc20.png")
  erc20QrUrl   String  @default("images/erc20.png")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ReferralReward {
  id             Int         @id @default(autoincrement())
  referrer       User        @relation("ReferralRewardReferrer", fields: [referrerId], references: [id])
  referrerId     Int
  referredUser   User        @relation("ReferralRewardReferredUser", fields: [referredUserId], references: [id])
  referredUserId Int
  transaction    Transaction @relation(fields: [transactionId], references: [id])
  transactionId  Int
  amount         Decimal     @db.Decimal(18, 6)
  createdAt      DateTime    @default(now())

  @@unique([referrerId, transactionId])
  @@index([referrerId, createdAt])
  @@index([referredUserId, createdAt])
  @@index([transactionId])
}

model WalletLedger {
  id           Int      @id @default(autoincrement())
  user         User     @relation(fields: [userId], references: [id])
  userId       Int
  type         String
  amount       Decimal  @db.Decimal(18, 6)
  balanceAfter Decimal  @db.Decimal(18, 6)
  referenceId  String?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([referenceId])
}

model AdminActionLog {
  id        Int      @id @default(autoincrement())
  admin     Admin    @relation(fields: [adminId], references: [id])
  adminId   Int
  action    String
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([action, createdAt])
}
